{
  "name": "morning-feed",
  "version": "1.0.0",
  "description": "Personal newsletter aggregator powered by AgentMail",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "intake": "tsx src/vpsIntakeServer.ts",
    "intake:prod": "node dist/vpsIntakeServer.js",
    "digest": "tsx src/index.ts",
    "digest:send": "tsx src/index.ts --send",
    "digest:cleanup": "tsx src/index.ts --cleanup-only",
    "digest:mastra": "tsx src/mastra/runDigestWorkflow.ts",
    "digest:mastra:dry": "tsx src/mastra/runDigestWorkflow.ts --dry-run",
    "check": "tsc --noEmit -p tsconfig.json",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "keywords": [
    "newsletter",
    "agentmail",
    "digest",
    "email"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@mastra/core": "^1.24.1",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5",
    "ollama-ai-provider-v2": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
