# AgentMail API configuration
AGENTMAIL_ADMIN_API_KEY=replace-with-your-api-key
AGENTMAIL_SENDING_API_KEY=replace-with-your-api-key
AGENTMAIL_API_BASE_URL=https://api.agentmail.to/v0
AGENTMAIL_MESSAGES_PATH=/inboxes/{inbox_id}/messages
AGENTMAIL_AUTH_HEADER=Authorization
AGENTMAIL_AUTH_PREFIX=Bearer
AGENTMAIL_ADMIN_INBOX_ID=replace-with-your-admin-inbox-id-or-address
AGENTMAIL_SENDING_INBOX_ID=replace-with-your-sending-inbox-id-or-address
AGENTMAIL_INBOX_PARAM=inbox
AGENTMAIL_DATE_FROM_PARAM=after
AGENTMAIL_DATE_TO_PARAM=before
# Kept for compatibility, but this project always sends YYYY-MM-DD.
AGENTMAIL_DATE_FORMAT=yyyy-mm-dd
AGENTMAIL_EXTRA_QUERY_JSON={"labels":"received"}

# Digest configuration
DIGEST_RECIPIENT_EMAIL=you@example.com
# Optional CSV list for fanout sends; when set, digest:send sends to all listed recipients.
DIGEST_RECIPIENT_EMAILS=
# Preferred recipient source for send job; JSON file with string array or {"recipients": [...]}
DIGEST_SUBSCRIBERS_FILE=data/subscribers.json
# Optional alert recipient for job status emails (defaults to DIGEST_RECIPIENT_EMAIL).
DIGEST_ALERT_RECIPIENT_EMAIL=
# Set false to disable success/failure status alert emails.
DIGEST_ALERTS_ENABLED=true
DIGEST_TIMEZONE=America/Los_Angeles
DIGEST_MAX_ITEMS=100
DIGEST_OUTPUT_DIR=output/digests
DIGEST_OUTPUT_RETENTION_DAYS=14

# AI summarization configuration (required)
AI_PROVIDER=ollama
AI_MAX_CHARS_PER_ITEM=6000
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:31b-cloud
OLLAMA_TIMEOUT_MS=90000
OLLAMA_MAX_RETRIES=2
OLLAMA_RETRY_BACKOFF_MS=1500

# Optional: set to true to print digest in terminal and skip delivery.
DIGEST_DRY_RUN=false
