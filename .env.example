# AgentMail API configuration
AGENTMAIL_API_KEY=replace-with-your-api-key
AGENTMAIL_API_BASE_URL=https://api.agentmail.to/v0
AGENTMAIL_MESSAGES_PATH=/inboxes/{inbox_id}/messages
AGENTMAIL_AUTH_HEADER=Authorization
AGENTMAIL_AUTH_PREFIX=Bearer
AGENTMAIL_INBOX_ID=replace-with-your-inbox-id-or-address
AGENTMAIL_INBOX_PARAM=inbox
AGENTMAIL_DATE_FROM_PARAM=after
AGENTMAIL_DATE_TO_PARAM=before
# Kept for compatibility, but this project always sends YYYY-MM-DD.
AGENTMAIL_DATE_FORMAT=yyyy-mm-dd
AGENTMAIL_EXTRA_QUERY_JSON={"labels":"received"}

# Digest configuration
DIGEST_RECIPIENT_EMAIL=you@example.com
DIGEST_TIMEZONE=America/Los_Angeles
DIGEST_MAX_ITEMS=100

# AI summarization configuration (required)
AI_PROVIDER=ollama
AI_MAX_CHARS_PER_ITEM=6000
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:31b-cloud
OLLAMA_TIMEOUT_MS=30000

# Optional: set to true to print digest in terminal and skip delivery.
DIGEST_DRY_RUN=false
